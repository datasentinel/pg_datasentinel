SET client_min_messages = WARNING;
-- Load the parent extension first
CREATE EXTENSION pg_datasentinel;
-- Load test extension
CREATE EXTENSION test_pg_datasentinel_internals;
-- Test pgds_parse_table_from_message() from pgds_utils.c
SELECT test_pgds_parse_table_from_message();
               test_pgds_parse_table_from_message                
-----------------------------------------------------------------
 Test: vacuum: schemaname = public                          PASS+
 Test: vacuum: relname = mytable                            PASS+
 Test: aggressive vacuum: schemaname = pg_catalog           PASS+
 Test: aggressive vacuum: relname = pg_class                PASS+
 Test: wraparound vacuum: schemaname = myschema             PASS+
 Test: wraparound vacuum: relname = orders                  PASS+
 Test: analyze: schemaname = public                         PASS+
 Test: analyze: relname = pgbench_accounts                  PASS+
 Test: no match: schemaname is empty                        PASS+
 Test: no match: relname is empty                           PASS+
 Test: missing close quote: schemaname is empty             PASS+
 Test: missing close quote: relname is empty                PASS+
 Test: one dot: schemaname is empty                         PASS+
 Test: one dot: relname is empty                            PASS+
                                                                +
 All tests PASSED                                               +
 
(1 row)

